# ============================================
# SmartCity AI Dashboard — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to version control.

# Hugging Face API Key (required for chatbot + image generation)
# Get one free at: https://huggingface.co/settings/tokens
VITE_HF_API_KEY=your_huggingface_api_key_here

# OpenRouter API Key (optional — alternative chatbot backend)
# Get one at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
